---
const exploreItems = [
  { text: "Home", href: "/" },
  { text: "Empresa", href: "/#empresa" },
  { text: "Tours", href: "/#tours" },
  { text: "Paquetes", href: "/#paquetes" },
  { text: "Blog", href: "/#" },
  { text: "Transporte", href: "/#transporte" },
];

const resourceItems = [
  { text: "Videos", href: "/#" },
  { text: "Politica de Privacidad", href: "/#" },
  { text: "Terminos y Condiciones", href: "/#" },
  { text: "Sitemap", href: "/#" },
];

const currentYear = new Date().getFullYear();
---

<footer class="bg-brand-dark text-white pt-24 pb-12 px-6 overflow-hidden">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row">
      <!-- Top Section: CTA -->
      <div>
        <h2
          class="text-5xl md:text-7xl font-medium tracking-tight mb-12 max-w-2xl text-brand-light/90"
        >
          ¿Tienes un viaje en mente?
        </h2>
        <div>
          <a
            href="https://wa.me/51987654321"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-3 bg-brand-primary hover:bg-brand-primary-dark text-white px-8 py-4 rounded-full text-lg font-medium transition-all duration-300 group shadow-lg"
          >
            Contáctanos por WhatsApp
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="transition-transform duration-300 group-hover:translate-x-1 group-hover:-translate-y-1"
            >
              <line x1="7" y1="17" x2="17" y2="7"></line>
              <polyline points="7 7 17 7 17 17"></polyline>
            </svg>
          </a>
        </div>
      </div>

      <!-- Middle Section: Links Grid -->
      <div class="grid grid-cols-1 md:grid-cols-12 gap-12 mb-24">
        <div class="md:col-span-6">
          <!-- Optional space for logo or other info if needed, keeping it clean like the image -->
        </div>

        <div class="md:col-span-3">
          <h3
            class="text-brand-primary text-base font-bold uppercase tracking-widest mb-8"
          >
            Explorar
          </h3>
          <ul class="space-y-4">
            {
              exploreItems.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class="text-base text-brand-light/60 hover:text-brand-primary transition-colors duration-200"
                  >
                    {item.text}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="md:col-span-3">
          <h3
            class="text-brand-primary text-base font-bold uppercase tracking-widest mb-8"
          >
            Recursos
          </h3>
          <ul class="space-y-4">
            {
              resourceItems.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class="text-base text-brand-light/60 hover:text-brand-primary transition-colors duration-200"
                  >
                    {item.text}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>

    <!-- Bottom Section: Copyright & Socials -->
    <div
      class="pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-8"
    >
      <p class="text-brand-light/30 text-sm">
        © {currentYear} exploreperu.com. All rights reserved.
      </p>

      <div class="flex items-center gap-4">
        <!-- TikTok -->
        <a
          href="#"
          class="w-12 h-12 rounded-full border border-white/10 flex items-center justify-center text-brand-light/60 hover:bg-white/5 hover:text-white transition-all duration-300"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path>
          </svg>
        </a>
        <!-- Facebook -->
        <a
          href="#"
          class="w-12 h-12 rounded-full border border-white/10 flex items-center justify-center text-brand-light/60 hover:bg-white/5 hover:text-white transition-all duration-300"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path
              d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"
            ></path>
          </svg>
        </a>
        <!-- Youtube -->
        <a
          href="#"
          class="w-12 h-12 rounded-full border border-white/10 flex items-center justify-center text-brand-light/60 hover:bg-white/5 hover:text-white transition-all duration-300"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path
              d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"
            ></path>
            <polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"
            ></polygon>
          </svg>
        </a>
        <!-- Instagram -->
        <a
          href="#"
          class="w-12 h-12 rounded-full border border-white/10 flex items-center justify-center text-brand-light/60 hover:bg-white/5 hover:text-white transition-all duration-300"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
