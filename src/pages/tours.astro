---
import Layout from "@/layout/Layout.astro";
import TourCard from "@/components/TourCard.astro";

const allTours = [
  { 
    title: "Tours a Machupicchu (Full Day)", 
    days: "1 día", 
    difficulty: "Moderada",
    price: "$150"
  },
  { 
    title: "Tours a Machupicchu (2D/1N)", 
    days: "2 días", 
    difficulty: "Moderada",
    price: "$280"
  },
  { 
    title: "Camino Inca", 
    days: "4 días", 
    difficulty: "Difícil",
    price: "$550"
  },
  { 
    title: "Salkantay - Inka Jungle", 
    days: "5 días", 
    difficulty: "Moderada",
    price: "$480"
  },
  { 
    title: "City Tour", 
    days: "1 día", 
    difficulty: "Fácil",
    price: "$45"
  },
  { 
    title: "Valle Sagrado", 
    days: "1 día", 
    difficulty: "Fácil",
    price: "$65"
  },
  { 
    title: "Maras Moray", 
    days: "1 día", 
    difficulty: "Fácil",
    price: "$55"
  },
  { 
    title: "Valle Sur", 
    days: "1 día", 
    difficulty: "Fácil",
    price: "$50"
  },
  { 
    title: "Vinincunca", 
    days: "1 día", 
    difficulty: "Moderada",
    price: "$70"
  },
  { 
    title: "Laguna Humantay", 
    days: "1 día", 
    difficulty: "Moderada",
    price: "$60"
  },
  { 
    title: "Waqrapukara", 
    days: "2 días", 
    difficulty: "Moderada",
    price: "$180"
  },
  { 
    title: "7 Lagunas de Ausangate", 
    days: "2 días", 
    difficulty: "Moderada",
    price: "$170"
  },
  { 
    title: "Qeswachaqa", 
    days: "1 día", 
    difficulty: "Moderada",
    price: "$65"
  },
];
---

<Layout>
  <section class="pt-32 pb-24 px-6 bg-brand-bg min-h-screen">
    <div class="max-w-7xl mx-auto">
      <div class="mb-16 text-center">
        <span class="inline-flex items-center px-4 py-1.5 rounded-full bg-brand-primary/10 text-brand-primary text-sm font-semibold mb-6 border border-brand-primary/20">
          <span class="w-1.5 h-1.5 rounded-full bg-brand-primary mr-2"></span>
          Nuestras Experiencias
        </span>
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-medium tracking-tight text-brand-dark leading-[1.1] mb-6">
          Tours & <span class="text-brand-primary italic">Experiencias</span>
        </h1>
        <p class="text-lg md:text-xl text-brand-dark-muted max-w-2xl mx-auto">
          Descubre los mejores destinos del Perú con nuestras experiencias únicas, diseñadas para crear recuerdos inolvidables.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {allTours.map((tour) => (
          <TourCard {...tour} />
        ))}
      </div>

      <div class="mt-16 text-center">
        <a
          href="/#contacto"
          class="btn-brand px-10 py-4 rounded-full font-bold inline-flex items-center gap-2 shadow-lg hover:-translate-y-0.5 hover:shadow-xl hover:shadow-brand-primary/20 transition-all duration-300"
        >
          Solicitar Información
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>
</Layout>
